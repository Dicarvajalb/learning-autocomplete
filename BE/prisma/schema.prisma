generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum QuizDifficulty {
  EASY
  MEDIUM
  HARD
}

enum QuestionType {
  AUTOCOMPLETE_ORDER
}

enum QuestionOptionLabel {
  HIDE
  SHOW
  EXTRA
}

enum QuizSessionMode {
  SOLO
  TWO_PLAYER
}

enum QuizSessionStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
  EXPIRED
}

enum SessionParticipantSeat {
  SOLO
  PLAYER_ONE
  PLAYER_TWO
}

enum AuditAction {
  CREATE
  UPDATE
  SAVE
  DELETE
  LOGIN
  LOGOUT
  REVOKE
}

model User {
  id           String               @id @default(cuid())
  oAuthSubject String?              @unique
  email        String?              @unique
  displayName  String
  role         UserRole             @default(USER)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  sessions     AuthSession[]
  quizSessions SessionParticipant[]
  auditEvents  AuditEvent[]

  @@index([role])
  @@index([displayName])
}

model AuthSession {
  id            String    @id @default(cuid())
  userId        String
  accessTokenId String?
  expiresAt     DateTime
  revokedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model Quiz {
  id          String         @id @default(cuid())
  title       String
  topic       String
  difficulty  QuizDifficulty
  description String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  questions   Question[]
  sessions    QuizSession[]
  auditEvents AuditEvent[]

  @@index([title])
  @@index([topic, difficulty])
}

model Question {
  id          String           @id @default(cuid())
  quizId      String
  description String
  type        QuestionType     @default(AUTOCOMPLETE_ORDER)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  quiz        Quiz             @relation(fields: [quizId], references: [id], onDelete: Cascade)
  options     QuestionOption[]
  answers     Answer[]

  @@index([quizId])
}

model QuestionOption {
  id          String              @id @default(cuid())
  questionId  String
  word        String
  label       QuestionOptionLabel
  optionOrder Int
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  question    Question            @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, optionOrder])
  @@index([questionId])
}

model QuizSession {
  id              String               @id @default(cuid())
  quizId          String
  mode            QuizSessionMode
  status          QuizSessionStatus    @default(PENDING)
  joinCode        String?              @unique
  shareLink       String?              @unique
  currentQuestion Int                  @default(0)
  startedAt       DateTime?
  completedAt     DateTime?
  expiresAt       DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  quiz            Quiz                 @relation(fields: [quizId], references: [id], onDelete: Restrict)
  participants    SessionParticipant[]
  answers         Answer[]

  @@index([quizId])
  @@index([status])
  @@index([joinCode])
  @@index([createdAt])
}

model SessionParticipant {
  id             String                 @id @default(cuid())
  sessionId      String
  userId         String?
  seat           SessionParticipantSeat
  joinedAt       DateTime               @default(now())
  lastAnsweredAt DateTime?
  lastAnswerMs   Int?
  session        QuizSession            @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user           User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)
  answers        Answer[]

  @@unique([sessionId, seat])
  @@unique([sessionId, userId])
  @@index([sessionId])
  @@index([userId])
}

model Answer {
  id            String             @id @default(cuid())
  sessionId     String
  participantId String
  questionId    String
  selectedOrder String[]
  isCorrect     Boolean
  scoreAwarded  Decimal            @db.Decimal(4, 1)
  answeredAt    DateTime           @default(now())
  session       QuizSession        @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  participant   SessionParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  question      Question           @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, participantId, questionId])
  @@index([sessionId])
  @@index([participantId])
  @@index([questionId])
  @@index([answeredAt])
}

model AuditEvent {
  id           String      @id @default(cuid())
  actorUserId  String?
  quizId       String?
  action       AuditAction
  targetEntity String
  targetId     String
  metadata     Json?
  createdAt    DateTime    @default(now())
  actorUser    User?       @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  quiz         Quiz?       @relation(fields: [quizId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([quizId])
  @@index([targetEntity, targetId])
  @@index([createdAt])
}
