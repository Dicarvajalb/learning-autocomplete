{
  "compilerOptions": {
    "allowJs": false,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "lib": ["ES2020"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2020",
    "types": ["react", "react-dom", "react-native"]
  },
  "include": ["**/*.ts", "**/*.tsx", "**/*.js", "vite-env.d.ts", "vite.config.ts"]
}
